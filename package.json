{
  "name": "coins-hold-and-win",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Coins: Hold & Win — a classic-style 3x3 slot demo built with PixiJS v8 (WebGL).",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src scripts test verify.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:proof": "vitest run test/rng-stats.test.js test/rtp-target.test.js test/property.test.js",
    "test:watch": "vitest",
    "mutation": "node scripts/mutation-probe.mjs",
    "audit": "node scripts/audit-drift.mjs",
    "smoke:browser": "node scripts/browser-smoke.mjs",
    "smoke:browser:planted": "node scripts/browser-smoke.mjs --planted-bad=settings-open"
  },
  "dependencies": {
    "pixi-filters": "^6.1.4",
    "pixi.js": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.6.0",
    "lil-gui": "^0.21.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "stats.js": "^0.17.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
